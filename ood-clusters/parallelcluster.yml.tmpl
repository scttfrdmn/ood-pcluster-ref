---
# OOD cluster configuration template for AWS ParallelCluster.
# Generated by scripts/gen-cluster-yaml.sh or fill in manually.
#
# Copy to /etc/ood/config/clusters.d/<cluster-name>.yml on the OOD portal node.
v2:
  metadata:
    title: "{{ cluster_title }}"
    hidden: false
  login:
    host: "{{ head_node_hostname }}"
  job:
    adapter: "slurm"
    submit_host: "{{ head_node_hostname }}"
    bin: "/opt/slurm/bin"
    conf: "/opt/slurm/etc/slurm.conf"
    # OOD wraps sbatch/squeue/scancel — use the wrappers for proper user mapping
    bin_overrides:
      sbatch: "%{OOD_PORTAL_DIR}/bin/slurm/sbatch"
      squeue: "%{OOD_PORTAL_DIR}/bin/slurm/squeue"
      scancel: "%{OOD_PORTAL_DIR}/bin/slurm/scancel"
  custom:
    queues:
      - name: "{{ default_partition }}"
        max_cores: {{ max_cores_per_job }}
        max_memory_gb: {{ max_memory_gb }}
