---
# OOD cluster configuration template for AWS ParallelCluster.
# Generated by scripts/gen-cluster-yaml.sh or fill in manually.
#
# Copy to /etc/ood/config/clusters.d/<cluster-name>.yml on the OOD portal node.
#
# Schema: this is the OOD clusters.d `v2` config schema, which is current in OOD
# 3.x AND 4.x — `v2` is the config-format version, not the OOD version. There is no
# `v3` clusters.d schema. Verified against the OOD 4.2 Slurm resource-manager docs.
v2:
  metadata:
    title: "{{ cluster_title }}"
    hidden: false
  login:
    host: "{{ head_node_hostname }}"
  job:
    adapter: "slurm"
    submit_host: "{{ head_node_hostname }}"
    bin: "/opt/slurm/bin"
    conf: "/opt/slurm/etc/slurm.conf"
    # OOD 4.x issues Slurm CLI commands with --export=NONE by default, which drops
    # the job environment and breaks srun/env propagation. copy_environment=true
    # restores --export=ALL behavior so submitted jobs inherit the environment.
    copy_environment: "true"
    # OOD wraps the Slurm client binaries — use the wrappers for proper user mapping
    bin_overrides:
      sbatch: "%{OOD_PORTAL_DIR}/bin/slurm/sbatch"
      squeue: "%{OOD_PORTAL_DIR}/bin/slurm/squeue"
      scancel: "%{OOD_PORTAL_DIR}/bin/slurm/scancel"
      scontrol: "%{OOD_PORTAL_DIR}/bin/slurm/scontrol"
  # `custom` is free-form data for this template/generator (e.g. surfacing the
  # default partition and limits); OOD itself does not consume these keys.
  custom:
    queues:
      - name: "{{ default_partition }}"
        max_cores: {{ max_cores_per_job }}
        max_memory_gb: {{ max_memory_gb }}
